{
  "$schema": "https://docs.openclaw.ai/schemas/plugin.json",
  "id": "bluesky",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {}
  },
  "channels": ["bluesky"],
  "channelEnvVars": {
    "bluesky": ["BLUESKY_HANDLE", "BLUESKY_APP_PASSWORD"]
  },
  "channelConfigs": {
    "bluesky": {
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "title": "Bluesky channel",
        "description": "AT Protocol account credentials. Use an app password from https://bsky.app/settings/app-passwords.",
        "properties": {
          "enabled": { "type": "boolean" },
          "handle": {
            "type": "string",
            "title": "Handle",
            "description": "Your Bluesky handle (e.g. you.bsky.social).",
            "examples": ["you.bsky.social"]
          },
          "appPassword": {
            "title": "App password",
            "description": "App password (NOT your account password). Create one at https://bsky.app/settings/app-passwords.",
            "oneOf": [
              { "type": "string" },
              {
                "type": "object",
                "properties": {
                  "source": { "enum": ["env", "file", "exec"] },
                  "provider": { "type": "string" },
                  "id": { "type": "string" }
                },
                "required": ["source", "id"],
                "additionalProperties": false
              }
            ]
          },
          "service": {
            "type": "string",
            "title": "PDS service URL",
            "description": "AT Protocol service endpoint. Defaults to the public Bluesky PDS.",
            "default": "https://bsky.social"
          },
          "accounts": {
            "type": "object",
            "description": "Multi-account overrides keyed by accountId. Each account follows the same shape as the top-level fields.",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "handle": { "type": "string" },
                "appPassword": {
                  "oneOf": [
                    { "type": "string" },
                    {
                      "type": "object",
                      "properties": {
                        "source": { "enum": ["env", "file", "exec"] },
                        "provider": { "type": "string" },
                        "id": { "type": "string" }
                      },
                      "required": ["source", "id"],
                      "additionalProperties": false
                    }
                  ]
                },
                "service": { "type": "string" },
                "enabled": { "type": "boolean" }
              },
              "required": ["handle", "appPassword"]
            }
          }
        },
        "required": ["handle", "appPassword"],
        "additionalProperties": false
      }
    }
  },
  "activation": {
    "onStartup": false
  }
}
